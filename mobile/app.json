{
  "expo": {
    "name": "Life Score", "slug": "life-score", "version": "1.0.0",
    "orientation": "portrait", "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifescore.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Life Score reads your Apple Health data to calculate your daily life score.",
        "NSHealthUpdateUsageDescription": "Life Score may write workout data back to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": { "package": "com.lifescore.app" },
    "plugins": [["react-native-health", { "isClinicalDataEnabled": false }]],
    "scheme": "lifescore"
  }
}